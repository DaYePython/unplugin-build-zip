{
  "name": "unplugin-build-zip-monorepo",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* run build",
    "test": "vitest run",
    "lint": "eslint .",
    "release": "bumpp package.json packages/unplugin-build-zip/package.json && pnpm -F @tonywater/unplugin-build-zip publish"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.13.2",
    "bumpp": "10.4.1",
    "eslint": "^9.27.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
